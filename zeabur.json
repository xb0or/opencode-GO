{
  "$schema": "https://schema.zeabur.app/template.json",
  "build": {
    "type": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "start": {
    "command": "/app/opencode-sw"
  },
  "healthCheck": {
    "type": "http",
    "path": "/health",
    "port": 3000
  },
  "volumes": [
    {
      "id": "data",
      "mountPath": "/data"
    }
  ],
  "variables": [
    { "key": "PORT", "value": "3000" },
    { "key": "DB_PATH", "value": "/data/opencode-sw.db" },
    { "key": "ADMIN_PASSWORD", "description": "Admin panel password (default: admin)" },
    { "key": "JWT_SECRET", "description": "Secret for admin JWT signing" },
    { "key": "GO_BASE_URL", "value": "https://opencode.ai/zen/go" },
    { "key": "UPSTREAM_TIMEOUT", "value": "120" }
  ]
}
