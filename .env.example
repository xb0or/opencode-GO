# =============================================================================
# opencode-go 环境变量配置
# 复制此文件为 .env 或直接在环境中设置
# =============================================================================

# --- 服务端口 ---
# 默认: 9812 (不常用端口，可避免冲突)
PORT=9812

# --- 管理员面板 ---
# 管理员登录密码（务必修改！）
ADMIN_PASSWORD=admin
# JWT 签名密钥（务必修改！）
JWT_SECRET=opencode-go-default-secret-change-me

# --- 数据库 ---
# SQLite 文件路径（Zeabur 部署建议挂载持久卷到 /data）
DB_PATH=./data/opencode-sw.db

# --- 上游 API 地址 ---
# Go 订阅套餐上游
GO_BASE_URL=https://opencode.ai/zen/go

# --- 模型路由映射 ---
# 将客户端请求中的 model 改写为另一个上游模型；支持 JSON 字符串或 JSON 文件。
# 示例：客户端请求 gpt-5.5 时，上游实际收到 glm-51。
# MODEL_MAPPINGS={"gpt-5.5":"glm-51"}
# MODEL_MAPPING_FILE=./config/model-mapping.example.json

# --- 计费倍率 ---
# 分组计费倍率，参与 UsageLog.actual_cost/account_cost 最终费用折算。
# 支持 JSON 或逗号分隔格式；未配置时默认 1.0。
# GROUP_MULTIPLIERS={"default":1,"go":0.8}
# GROUP_MULTIPLIERS=default=1,go=0.8

# --- 上游超时 ---
# 上游非流式请求超时时间（秒）；0 表示不由网关主动设置截止时间。
# 流式请求不受此限制，避免长输出在 120 秒等固定时长后被中断。
UPSTREAM_TIMEOUT=0
